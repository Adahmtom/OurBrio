# Convex (set automatically by `npx convex dev`)
CONVEX_DEPLOYMENT="dev:your-deployment-name"
NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"

# Convex Auth (set in Convex dashboard environment variables)
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# SITE_URL="https://ourbrio.com"

# Gmail for Nodemailer (optional - for email notifications)
GMAIL_USER="OurBrio@gmail.com"
GMAIL_APP_PASSWORD="your-16-character-app-password"
NOTIFICATION_EMAIL="OurBrio@gmail.com"
